---
import UserButton from './UserButton'
import CartButton from './CartButton'
import type { User } from '../types/Auth'
import { Icon } from 'astro-icon/components'

const userValue = Astro.cookies.get('auth-user')?.value
const user = userValue ? (JSON.parse(userValue) as User) : undefined
---

<header class='z-50 fixed top-0 flex h-16 w-full items-center justify-between bg-violet-900 px-4'>
  <a href='/' class='text-center text-2xl font-bold lg:text-4xl'> Retro Store </a>
  <div class='flex items-center gap-4'>
    <UserButton client:load user={user} />
    <CartButton client:only='react'>
      <div
        slot='fallback'
        class='rounded-full bg-violet-600 p-3 text-xl transition hover:bg-violet-800'
      >
        <Icon name='ri:shopping-cart-2-line' />
      </div>
      <Icon name='ri:shopping-cart-2-line' />
    </CartButton>
  </div>
</header>
