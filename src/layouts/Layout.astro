---
import Cart from '../components/Cart'
import ToastLayout from '../layouts/ToastLayout'
import Header from '../components/Header.astro'
import '../styles/global.css'
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <meta name='generator' content={Astro.generator} />
    <meta
      name='description'
      content='La Retro Store más rápida, segura y confiable para comprar videojuegos a buen precio.'
    />
    <title>Retro Store</title>
  </head>
  <body>
    <Header />
    <Cart client:only='react' />
    <main class='container mx-auto max-w-6xl p-4 mt-16'>
      <slot />
    </main>

    <ToastLayout client:load />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background-color: #1e2939;
    color: white;
  }
</style>
