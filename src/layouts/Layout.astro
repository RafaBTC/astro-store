---
import Header from '../components/Header'
import Cart from '../components/Cart'
import '../styles/global.css'
import { Icon } from 'astro-icon/components'
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <meta name='generator' content={Astro.generator} />
    <meta name='Página para comprar videojuegos a buen precio.' />
    <title>Retro Store</title>
  </head>
  <body>
    <Header client:only='react'>
      <Icon name='ri:shopping-cart-2-line' />
      <div
        slot='fallback'
        class='fixed top-0 flex h-16 w-full items-center justify-center bg-indigo-900'
      >
      </div>
    </Header>
    <Cart client:only='react' />
    <main class='container mx-auto max-w-6xl p-4 mt-16'>
      <slot />
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    background-color: #1e2939;
    color: white;
  }
</style>
