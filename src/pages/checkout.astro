---
import OrderSummary from '../components/E-Commerce/OrderSummary'
import PaypalPayment from '../components/E-Commerce/PaypalPayment'
import Layout from '../layouts/Layout.astro'

const { user } = Astro.locals
const location = Astro.url.pathname
---

<Layout>
  <h1 class='text-3xl font-bold mb-5'>Finalizar compra</h1>

  <div class='flex flex-col lg:flex-row justify-between gap-12'>
    <PaypalPayment client:load>
      <a
        href='/cart'
        class='my-4 w-full block rounded-lg bg-violet-600 px-4 py-2 text-center text-lg font-bold transition hover:bg-violet-700'
      >
        Volver al carrito
      </a>
    </PaypalPayment>
    <div>
      <OrderSummary client:only='react' user={user} location={location} readOnly />
    </div>
  </div>
</Layout>
